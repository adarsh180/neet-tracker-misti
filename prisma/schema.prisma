// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Subject {
  id          String    @id @default(cuid())
  slug        String    @unique // botany, zoology, physics, chemistry
  name        String
  emoji       String
  color       String    // hex color for UI
  topics      Topic[]
  dailyGoals  DailyGoal[]
  testRecords TestRecord[]
  errorPatterns ErrorPattern[]
  tasks       Task[]
  missionSessions MissionSession[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("subjects")
}

model Topic {
  id             String    @id @default(cuid())
  subjectId      String
  subject        Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  name           String
  chapter        String?   // chapter name/number
  chapterOrder   Int       @default(0)
  classLevel     String?   // "11" or "12"
  topicOrder     Int       @default(0)
  isCompleted    Boolean   @default(false)
  completedAt    DateTime?
  questionsSolved Int      @default(0)
  revisions      Revision[]
  
  // Spaced Repetition System (SRS)
  nextReviewDate DateTime?
  easeFactor     Float     @default(2.5) // SuperMemo-2 
  interval       Int       @default(0)   // Days until next review

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("topics")
}

model Revision {
  id        String   @id @default(cuid())
  topicId   String
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  note      String?  @db.Text
  revisedAt DateTime @default(now())

  @@map("revisions")
}

model DailyGoal {
  id             String   @id @default(cuid())
  subjectId      String
  subject        Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  date           DateTime @db.Date
  hoursStudied   Float    @default(0)
  questionsSolved Int     @default(0)
  disciplineScore Int     @default(0)
  completionPercent Int   @default(0)
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([subjectId, date])
  @@map("daily_goals")
}

model ScreenTimeLog {
  id           String   @id @default(cuid())
  userId       String   @default("misti")
  date         DateTime @db.Date
  instagram    Float    @default(0)
  whatsapp     Float    @default(0)
  youtube      Float    @default(0)
  youtubeStudy Float    @default(0)
  facebook     Float    @default(0)
  netflix      Float    @default(0)
  hotstar      Float    @default(0)
  mxPlayer     Float    @default(0)
  google       Float    @default(0)
  other        Float    @default(0)
  note         String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
  @@map("screen_time_logs")
}

model TestRecord {
  id          String     @id @default(cuid())
  subjectId   String?
  subject     Subject?   @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  testType    String     // SECTIONAL, FULL_LENGTH, AITS, UNIT_TEST
  testName    String
  score       Float
  maxScore    Float
  percentage  Float
  rank        Int?
  totalStudents Int?
  institute   String?
  staminaDecay Int?       // 1-10 rating on mental fatigue post-test
  correctCount Int?
  wrongCount   Int?
  skippedCount Int?
  guessedCount Int?
  negativeMarksLost Float?
  physicsScore    Float?
  chemistryScore  Float?
  botanyScore     Float?
  zoologyScore    Float?
  physicsTimeMinutes   Int?
  chemistryTimeMinutes Int?
  botanyTimeMinutes    Int?
  zoologyTimeMinutes   Int?
  difficultyLevel String?
  reliabilityLevel String?
  linkedErrorLogTestId String?
  takenAt     DateTime
  notes       String?    @db.Text
  createdAt   DateTime   @default(now())

  @@index([linkedErrorLogTestId])
  @@map("test_records")
}

model ErrorLogTest {
  id              String             @id @default(cuid())
  testName        String
  testType        String             // AITS, SECTIONAL, UNIT, FLT, PYQ, REAL_ATTEMPT
  questionCount   Int
  takenAt         DateTime           @default(now())
  notes           String?            @db.Text
  questions       ErrorLogQuestion[]
  analyses        ErrorLogAnalysis[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([testType, takenAt])
  @@map("error_log_tests")
}

model ErrorLogQuestion {
  id              String       @id @default(cuid())
  testId          String
  test            ErrorLogTest @relation(fields: [testId], references: [id], onDelete: Cascade)
  questionNumber  Int
  questionSummary String?      @db.Text
  subject         String
  chapter         String?
  topic           String?
  attemptStatus   String       @default("SKIPPED") // ATTEMPTED, SKIPPED
  outcome         String       @default("UNMARKED") // CORRECT, WRONG, UNMARKED
  correctAnswer   String?      @db.Text
  whyCorrect      String?      @db.Text
  whereLacked     String?      @db.Text
  contentStatus   String       @default("HAD_CONTENT") // HAD_CONTENT, WEAK_CONTENT, NOT_STUDIED, OUT_OF_SYLLABUS
  outOfSyllabus   Boolean      @default(false)
  notStudied      Boolean      @default(false)
  difficulty      String       @default("MEDIUM") // EASY, MEDIUM, HARD
  solveMethod     String?      // DIRECT, ELIMINATION, GUESS, BLIND_GUESS
  optionsEliminated Int?       // 0-3 options ruled out before answering
  confidence      Int?
  timeSpentSeconds Int?
  reasonTags      Json?
  actionFix       String?      @db.Text
  notes           String?      @db.Text
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([subject, chapter])
  @@index([outcome, contentStatus])
  @@map("error_log_questions")
}

model ErrorLogAnalysis {
  id            String        @id @default(cuid())
  testId        String
  test          ErrorLogTest  @relation(fields: [testId], references: [id], onDelete: Cascade)
  response      String        @db.LongText
  model         String?
  summaryJson   Json?
  createdAt     DateTime      @default(now())

  @@index([testId, createdAt])
  @@map("error_log_analyses")
}

model ErrorLogGlobalAnalysis {
  id            String   @id @default(cuid())
  response      String   @db.LongText
  model         String?
  summaryJson   Json?
  createdAt     DateTime @default(now())

  @@map("error_log_global_analyses")
}

model CycleEntry {
  id          String    @id @default(cuid())
  userId      String    @default("misti")
  startDate   DateTime  @db.Date
  endDate     DateTime? @db.Date
  flowLevel   String    // LIGHT, MODERATE, HEAVY, SPOTTING
  symptoms    String?   @db.Text
  mood        String?   // HAPPY, ANXIOUS, TIRED, NORMAL, CRAMPY
  notes       String?   @db.Text
  dayDetails  Json?
  createdAt   DateTime  @default(now())

  @@index([userId, startDate])
  @@map("cycle_entries")
}

model CyclePrediction {
  id                String   @id @default(cuid())
  userId            String   @default("misti")
  currentPhase      String
  dayOfCycle        Int?
  predictedStart    DateTime @db.Date
  windowStart       DateTime @db.Date
  windowEnd         DateTime @db.Date
  confidence        Float
  confidenceLabel   String
  averageCycleLength Float
  cycleVariability  Float
  evidenceJson      Json
  createdAt         DateTime @default(now())

  @@index([userId, createdAt])
  @@map("cycle_predictions")
}

model AiConversation {
  id        String       @id @default(cuid())
  title     String?
  mode      String       @default("neet-guru") // neet-guru, rank, quiz, cycle
  messages  AiMessage[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@map("ai_conversations")
}

model AiMessage {
  id             String         @id @default(cuid())
  conversationId String
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String         // user | assistant
  content        String         @db.LongText
  attachmentsJson Json?
  createdAt      DateTime       @default(now())

  @@map("ai_messages")
}

model AiMemoryProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  displayName         String
  version             Int      @default(1)
  stats               Json
  preferences         Json
  strengths           Json
  weaknesses          Json
  misconceptions      Json
  behavioralPatterns  Json
  conversationSnapshots Json
  rollingSummary      String   @db.LongText
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("ai_memory_profiles")
}

model AppNotification {
  id             String   @id @default(cuid())
  title          String
  body           String   @db.Text
  tone           String   @default("focus")
  senderLabel    String
  senderClientId String?
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([senderClientId])
  @@map("app_notifications")
}

model PushSubscription {
  id             String   @id @default(cuid())
  endpoint       String   @unique @db.VarChar(768)
  p256dh         String   @db.VarChar(255)
  auth           String   @db.VarChar(255)
  senderClientId String?  @db.VarChar(80)
  userAgent      String?  @db.VarChar(320)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([senderClientId])
  @@map("push_subscriptions")
}

model RankPrediction {
  id              String   @id @default(cuid())
  predictedRank   Int
  predictedScore  Float
  confidence      Float    // 0-100
  analysisJson    String   @db.LongText // JSON blob with full analysis
  createdAt       DateTime @default(now())

  @@map("rank_predictions")
}

model MoodEntry {
  id          String   @id @default(cuid())
  userId      String   @default("misti")
  date        DateTime @db.Date
  mood        String   // AMAZING, GOOD, OKAY, LOW, TERRIBLE
  energy      Int      // 1-10
  focus       Int      // 1-10
  stress      Int      // 1-10 (1=calm, 10=very stressed)
  note        String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([date])
  @@index([userId, date])
  @@map("mood_entries")
}

model PyqYearProgress {
  id            String    @id @default(cuid())
  userId        String
  exam          String
  year          String
  completed     Boolean   @default(false)
  revisionCount Int       @default(0)
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([userId, exam, year])
  @@index([userId, exam])
  @@map("pyq_year_progress")
}

model QuizSession {
  id          String   @id @default(cuid())
  subject     String
  topic       String?
  difficulty  String
  score       Int
  maxScore    Int
  accuracy    Float
  createdAt   DateTime @default(now())

  @@map("quiz_sessions")
}

model ErrorPattern {
  id          String   @id @default(cuid())
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  errorType   String   // e.g., "Calculation", "Formula", "Conceptual", "Silly"
  frequency   Int      @default(1)
  notes       String?  @db.Text
  updatedAt   DateTime @updatedAt
  
  @@map("error_patterns")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  SKIPPED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskSource {
  MANUAL
  AI
}

enum TaskAgentTrigger {
  START
  FINISH
  SKIP
  MANUAL
}

enum TaskAgentRunStatus {
  SUCCESS
  FAILED
}

enum TaskTimelineEventType {
  CREATED
  UPDATED
  STARTED
  COMPLETED
  SKIPPED
  AI_TRIGGERED
}

enum MissionKind {
  MISSION_PLANNER
  AUTO_TODO
  TEST_RECOVERY
  REVISION_PULSE
  DAILY_COMMAND
  PATTERN_DETECTOR
}

enum MissionSessionStatus {
  READY
  APPLIED
  ARCHIVED
}

model Task {
  id                String              @id @default(cuid())
  title             String
  description       String?             @db.Text
  status            TaskStatus          @default(TODO)
  priority          TaskPriority        @default(MEDIUM)
  source            TaskSource          @default(MANUAL)
  missionId         String?
  mission           MissionSession?     @relation(fields: [missionId], references: [id], onDelete: SetNull)
  subjectId         String?
  subject           Subject?            @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  dueDate           DateTime?           @db.Date
  plannedMinutes    Int?
  actualMinutes     Int?
  orderIndex        Int                 @default(0)
  lastAgentSummary  String?             @db.Text
  aiAssistEnabled   Boolean             @default(true)
  startedAt         DateTime?
  completedAt       DateTime?
  skippedAt         DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  agentRuns         TaskAgentRun[]
  timelineEvents    TaskTimelineEvent[]

  @@index([status, orderIndex])
  @@index([dueDate])
  @@index([missionId])
  @@map("tasks")
}

model TaskAgentRun {
  id              String              @id @default(cuid())
  taskId           String
  task             Task                @relation(fields: [taskId], references: [id], onDelete: Cascade)
  trigger          TaskAgentTrigger
  status           TaskAgentRunStatus  @default(SUCCESS)
  prompt           String              @db.LongText
  response         String              @db.LongText
  suggestionsJson  Json?
  model            String?
  createdAt        DateTime            @default(now())

  @@index([taskId, createdAt])
  @@map("task_agent_runs")
}

model TaskTimelineEvent {
  id          String                @id @default(cuid())
  taskId       String
  task         Task                  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  type         TaskTimelineEventType
  label        String
  detail       String?               @db.Text
  createdAt    DateTime              @default(now())

  @@index([taskId, createdAt])
  @@map("task_timeline_events")
}

model MissionSession {
  id                 String               @id @default(cuid())
  kind               MissionKind
  status             MissionSessionStatus @default(READY)
  title              String
  goal               String?              @db.Text
  summary            String?              @db.Text
  responseMarkdown   String               @db.LongText
  responseJson       Json
  model              String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  subjectId          String?
  subject            Subject?             @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  tasks              Task[]

  @@index([kind, createdAt])
  @@map("mission_sessions")
}

model ReviewCard {
  id            String    @id @default(cuid())
  userId        String    @default("misti")
  period        String    // WEEKLY | MONTHLY
  periodKey     String    // e.g. "2026-06-08" (week start) or "2026-05" (month)
  periodStart   DateTime  @db.Date
  periodEnd     DateTime  @db.Date
  status        String    @default("AWAITING_ANSWERS") // AWAITING_ANSWERS | COMPLETED
  reviewJson    Json      // the review card content
  questionsJson Json      // integrity questions incl. private evidence/expected answers
  answersJson   Json?     // her submitted answers
  verdictJson   Json?     // integrity verdict after evaluation
  model         String?
  notifiedAt    DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([period, periodKey])
  @@index([createdAt])
  @@map("review_cards")
}

model PracticeTest {
  id             String    @id @default(cuid())
  title          String
  mode           String    // FULL_LENGTH | SECTIONAL | UNIT | SUBJECT | CHAPTER | TOPIC | PYQ_YEAR
  subject        String?   // subject slug, null for full syllabus
  chapter        String?
  topic          String?
  pyqYear        String?
  questionCount  Int
  aiFreshPercent Int       @default(6)
  durationMinutes Int      @default(180)
  difficulty     String    @default("MIXED") // MIXED | EASY | MODERATE | TOUGH
  status         String    @default("GENERATING") // GENERATING | READY | RUNNING | PAUSED | COMPLETED
  filtersJson    Json?
  questionsJson  Json      // questions incl. private correctIndex/explanation
  weakZonesJson  Json?     // weak-zone snapshot used to steer generation
  answersJson    Json?
  questionStatusesJson Json?
  currentQuestionIndex Int @default(0)
  remainingSeconds Int?
  pauseLogsJson Json?
  securityEventsJson Json?
  submitType String?
  autoSubmitReason String?
  totalActiveSeconds Int?
  totalPausedSeconds Int?
  testSeed      String?
  blueprintVersion String?
  paperTemplate String?
  distributionAuditJson Json?
  blueprintWarningsJson Json?
  resultJson     Json?
  model          String?
  testRecordId   String?
  errorLogTestId String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, createdAt])
  @@map("practice_tests")
}

model BankQuestion {
  id           String    @id @default(cuid())
  subject      String
  classLevel   String?
  chapter      String
  topic        String?
  source       String
  sourceRef    String
  difficulty   String
  question     String    @db.Text
  optionsJson  Json
  correctIndex Int
  explanation  String    @db.Text
  verified     Boolean   @default(false)
  qualityStatus String   @default("UNVERIFIED") // UNVERIFIED | VERIFIED_STRICT | NEEDS_REVIEW | NEEDS_VISUAL_ASSET | REJECTED
  qualityScore  Float?
  verifiedAt    DateTime?
  rejectedAt    DateTime?
  verifierModel String?
  verifierRuns  Json?
  rejectReason  String?  @db.Text
  trendChapterId String?
  questionForm   String?
  subtopic       String?
  isDiagramBased Boolean  @default(false)
  isGraphBased   Boolean  @default(false)
  duplicateClusterId String?
  sourceQuality  Float?
  pyqSimilarityScore Float?
  trendMetaJson  Json?
  visualAssetUrl String?   @db.VarChar(768)
  visualAssetAlt String?   @db.Text
  visualAssetKind String?  @db.VarChar(40)
  visualMetaJson Json?
  contentHash  String    @unique @db.VarChar(64)
  timesServed  Int       @default(0)
  timesCorrect Int       @default(0)
  timesWrong   Int       @default(0)
  lastServedAt DateTime?
  importBatch  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([subject, chapter, difficulty])
  @@index([subject, chapter, source])
  @@index([subject, chapter, lastServedAt])
  @@index([subject, classLevel, trendChapterId])
  @@index([subject, classLevel, chapter, trendChapterId])
  @@index([questionForm])
  @@index([duplicateClusterId])
  @@index([visualAssetKind])
  @@map("bank_questions")
}

model BankFillJob {
  id        String   @id @default(cuid())
  subject   String
  chapter   String
  requested Int
  inserted  Int      @default(0)
  rejected  Int      @default(0)
  status    String   @default("RUNNING")
  model     String?
  error     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subject, chapter, createdAt])
  @@map("bank_fill_jobs")
}

model PyqDocument {
  id        String   @id @default(cuid())
  pathname  String   @unique
  fileData  Bytes    @db.LongBlob
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("pyq_documents")
}
