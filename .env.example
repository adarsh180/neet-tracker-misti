DATABASE_URL="mysql://username:password@gateway01.ap-southeast-1.prod.aws.tidbcloud.com:4000/neet_tracker?sslaccept=strict"
NEXT_PUBLIC_PYQ_BLOB_BASE_URL="https://your-store.public.blob.vercel-storage.com"
GEMINI_API_KEY="AIza...."
# Manual Practice Arena analysis uses Gemma 4 31B -> Gemma 4 26B ->
# Gemini 2.5 Flash -> Gemini 3.5 Flash. Gemini 3.1 Pro is never in this lane.

# Proctor integrity events remain stored with the attempt, but email delivery
# and camera-frame capture are held unless both switches are explicitly enabled.
PROCTOR_EMAIL_ENABLED="false"
NEXT_PUBLIC_PROCTOR_EMAIL_ENABLED="false"
RESEND_API_KEY="re_..."
PROCTOR_REPORT_FROM_EMAIL="NEET Practice <practice@your-verified-domain.example>"
PROCTOR_REPORT_TO_EMAIL="guardian@example.com"
MISTI_EMAIL="misti@example.com"
DIVYANI_EMAIL="divyani@example.com"
MISTI_PWD="replace-with-strong-password"
DIVYANI_PWD="replace-with-strong-password"

# Web Push is free. Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="public-vapid-key"
VAPID_PRIVATE_KEY="private-vapid-key"
VAPID_SUBJECT="mailto:you@example.com"

# Secures the daily cycle-nudge cron (/api/cron/cycle-nudge). Set the same value
# in Vercel project env; Vercel Cron sends it automatically as a Bearer token.
CRON_SECRET="replace-with-a-long-random-string"

# Cross-app notifications.
# In the NEET project this must point to the UPSC project, because it is the partner app.
CROSS_APP_NOTIFY_SECRET="same-random-secret-in-both-projects"
PARTNER_NOTIFY_ENDPOINT="https://upsc-cse-tracker-adarsh.vercel.app/api/cross-app-notifications"
